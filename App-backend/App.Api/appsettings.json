{
  "App": {
    "HackerNews": {
      "BaseAddress": "https://hacker-news.firebaseio.com/v0/",
      "HttpClientTimeoutSeconds": 10
    },
    "Cache": {
      "BestStoryIdsTtlSeconds": 300,
      "StoryDetailTtlSeconds": 180
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
